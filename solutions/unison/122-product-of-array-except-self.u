--
-- Problem 122: Product of Array Except Self (LeetCode 238)
-- Difficulty: Med
-- Language: Unison
--
-- Unison version for problem 122
-- Derived from the functional reference implementation already in the registry.
productExceptSelf : [Int] -> [Int]
productExceptSelf nums =
  let prefix = scanl (*) 1 nums
      suffix = scanr (*) 1 nums
  in zipWith (*) (init prefix) (tail suffix)
