--
-- Problem 60: Validate Binary Search Tree (LeetCode 98)
-- Difficulty: Med
-- Language: Unison
--
-- Unison version for problem 60
-- Derived from the functional reference implementation already in the registry.
data Tree a = Nil | Node a (Tree a) (Tree a)

isValidBST : (Ord a) => Tree a -> Bool
isValidBST = go None None
  where
    go _ _ Nil = True
    go lo hi (Node v l r) =
      maybe True (< v) lo &&
      maybe True (v <) hi &&
      go lo (Some v) l &&
      go (Some v) hi r
